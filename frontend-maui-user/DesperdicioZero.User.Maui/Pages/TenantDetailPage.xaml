<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DesperdicioZero.User.Maui.Pages.TenantDetailPage">
  <RefreshView x:Name="RefreshControl" Refreshing="OnRefreshing">
    <ScrollView>
      <VerticalStackLayout Padding="20,18,20,28" Spacing="18">
        <Border Style="{StaticResource HeroBorderStyle}">
          <VerticalStackLayout Spacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <VerticalStackLayout Spacing="4">
                <Label Style="{StaticResource HeroTitleStyle}" Text="{Binding Name}" />
                <Label IsVisible="{Binding HasLocation}" Text="{Binding LocationText}" TextColor="{StaticResource ColorSurface}" />
                <Label IsVisible="{Binding HasAddress}" Text="{Binding Address}" TextColor="{StaticResource ColorSurface}" />
              </VerticalStackLayout>

              <VerticalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End">
                <Border Background="{StaticResource ColorSurface}"
                        Padding="12,6"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 999"
                        VerticalOptions="Start">
                  <Label FontAttributes="Bold"
                         FontSize="12"
                         Text="{Binding StatusLabel}"
                         TextColor="{StaticResource ColorPrimaryDark}" />
                </Border>

                <Button x:Name="FavoriteButton"
                        Clicked="OnToggleFavoriteClicked"
                        Padding="14,10"
                        Style="{StaticResource OutlineButtonStyle}"
                        Text="Guardar" />
              </VerticalStackLayout>
            </Grid>

            <Label IsVisible="{Binding HasContact}" Text="{Binding ContactText}" TextColor="{StaticResource ColorSurface}" />

            <HorizontalStackLayout Spacing="10">
              <Button x:Name="OpenMapButton"
                      Clicked="OnOpenMapClicked"
                      IsVisible="False"
                      Padding="14,10"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Text="Ubicacion" />
              <Button x:Name="CallButton"
                      Clicked="OnCallClicked"
                      IsVisible="False"
                      Padding="14,10"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Text="Llamar" />
              <Button x:Name="EmailButton"
                      Clicked="OnEmailClicked"
                      IsVisible="False"
                      Padding="14,10"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Text="Email" />
            </HorizontalStackLayout>
          </VerticalStackLayout>
        </Border>

        <Border IsVisible="{Binding HasOperatingHours}" Style="{StaticResource CardBorderStyle}">
          <VerticalStackLayout Spacing="12">
            <Label Style="{StaticResource SectionTitleStyle}" Text="Horario" />
            <VerticalStackLayout x:Name="OperatingHoursLayout" Spacing="8">
              <BindableLayout.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18">
                    <Label FontAttributes="Bold" Text="{Binding Day}" />
                    <Label Grid.Column="1" HorizontalTextAlignment="End" Text="{Binding Hours}" TextColor="{StaticResource ColorMuted}" />
                  </Grid>
                </DataTemplate>
              </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
          </VerticalStackLayout>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
          <VerticalStackLayout Spacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <Label Style="{StaticResource SectionTitleStyle}" Text="Menu de hoy" />
              <Border Grid.Column="1"
                      Background="{StaticResource ColorSurfaceAlt}"
                      Padding="12,6"
                      StrokeThickness="0"
                      StrokeShape="RoundRectangle 999">
                <Label x:Name="MenuStatusLabel"
                       FontAttributes="Bold"
                       FontSize="12"
                       Text="Pendiente"
                       TextColor="{StaticResource ColorPrimaryDark}" />
              </Border>
            </Grid>

            <ActivityIndicator x:Name="MenuLoadingIndicator"
                               Color="{StaticResource ColorPrimary}"
                               IsRunning="False"
                               IsVisible="False" />

            <Grid x:Name="MenuStatsGrid"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  IsVisible="False">
              <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="2">
                  <Label x:Name="MenuDishCountLabel" Style="{StaticResource MetricValueStyle}" Text="0" />
                  <Label Style="{StaticResource MetricCaptionStyle}" Text="platos" />
                </VerticalStackLayout>
              </Border>

              <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="2">
                  <Label x:Name="MenuHighlightsLabel" Style="{StaticResource MetricValueStyle}" Text="0" />
                  <Label Style="{StaticResource MetricCaptionStyle}" Text="etiquetas dietarias" />
                </VerticalStackLayout>
              </Border>
            </Grid>

            <VerticalStackLayout x:Name="MenuContent" Spacing="14" IsVisible="False">
              <Label x:Name="MenuDateLabel" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource ColorSecondary}" />
              <Label x:Name="MenuTitleLabel" Style="{StaticResource CardTitleStyle}" />
              <Label x:Name="MenuDescriptionLabel" TextColor="{StaticResource ColorMuted}" />

              <VerticalStackLayout x:Name="MenuItemsLayout" Spacing="12">
                <BindableLayout.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{StaticResource ColorSurfaceAlt}"
                            Padding="16"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20">
                      <VerticalStackLayout Spacing="8">
                        <Label FontAttributes="Bold" FontSize="16" Text="{Binding Name}" />
                        <Label IsVisible="{Binding HasDescription}" Text="{Binding Description}" TextColor="{StaticResource ColorMuted}" />
                        <Label Text="{Binding IngredientsLabel}" />
                        <Label FontSize="12" Text="{Binding AllergensLabel}" TextColor="{StaticResource ColorMuted}" />
                        <Label FontSize="12" Text="{Binding DietaryFlagsLabel}" TextColor="{StaticResource ColorSecondary}" />
                      </VerticalStackLayout>
                    </Border>
                  </DataTemplate>
                </BindableLayout.ItemTemplate>
              </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="EmptyMenuState"
                                 IsVisible="False"
                                 Padding="8,2,8,4"
                                 Spacing="8">
              <Label HorizontalTextAlignment="Center"
                     Text="Este comedor aun no ha publicado su menu para hoy."
                     TextColor="{StaticResource ColorMuted}" />
              <Label HorizontalTextAlignment="Center"
                     Style="{StaticResource CaptionLabelStyle}"
                     Text="Puedes guardar el comedor en favoritos y volver mas tarde, o usar sus datos de contacto para confirmar horario y servicio." />
            </VerticalStackLayout>
          </VerticalStackLayout>
        </Border>
      </VerticalStackLayout>
    </ScrollView>
  </RefreshView>
</ContentPage>
