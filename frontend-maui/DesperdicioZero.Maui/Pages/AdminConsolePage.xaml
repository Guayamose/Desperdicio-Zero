<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DesperdicioZero.Maui.Pages.AdminConsolePage"
             Title="Consola Admin">
  <RefreshView x:Name="RefreshControl" Refreshing="OnRefreshing">
    <ScrollView>
      <VerticalStackLayout Padding="16" Spacing="12">
        <Label Text="Administración Global" FontSize="26" FontAttributes="Bold" />

        <Frame>
          <VerticalStackLayout Spacing="6">
            <Label Text="Métricas" FontSize="18" FontAttributes="Bold" />
            <Label x:Name="MetricsLabel" TextColor="{StaticResource ColorMuted}" />
          </VerticalStackLayout>
        </Frame>

        <Frame>
          <VerticalStackLayout Spacing="8">
            <Label x:Name="TenantEditorTitle" Text="Nuevo comedor" FontSize="18" FontAttributes="Bold" />
            <Entry x:Name="TenantNameEntry" Placeholder="Nombre" />
            <Entry x:Name="TenantSlugEntry" Placeholder="Slug" />
            <Entry x:Name="TenantCityEntry" Placeholder="Ciudad" />
            <Picker x:Name="TenantStatusPicker" Title="Estado" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <Button Text="Guardar comedor" Clicked="OnSaveTenantClicked" />
              <Button Grid.Column="1" Text="Nuevo" BackgroundColor="{StaticResource ColorSecondary}" Clicked="OnResetTenantClicked" />
            </Grid>
          </VerticalStackLayout>
        </Frame>

        <CollectionView x:Name="TenantsList" SelectionMode="None">
          <CollectionView.ItemTemplate>
            <DataTemplate>
              <Frame Margin="0,0,0,8">
                <VerticalStackLayout Spacing="6">
                  <Label Text="{Binding Name}" FontAttributes="Bold" />
                  <Label Text="{Binding Slug}" TextColor="{StaticResource ColorMuted}" />
                  <Label Text="{Binding Status}" TextColor="{StaticResource ColorSecondary}" />
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Text="Editar" BackgroundColor="{StaticResource ColorSecondary}" Clicked="OnEditTenantClicked" CommandParameter="{Binding .}" />
                    <Button Grid.Column="1" Text="Eliminar" BackgroundColor="{StaticResource ColorDanger}" Clicked="OnDeleteTenantClicked" CommandParameter="{Binding .}" />
                  </Grid>
                </VerticalStackLayout>
              </Frame>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>

        <Frame>
          <VerticalStackLayout Spacing="8">
            <Label Text="Crear usuario" FontSize="18" FontAttributes="Bold" />
            <Entry x:Name="UserNameEntry" Placeholder="Nombre completo" />
            <Entry x:Name="UserEmailEntry" Placeholder="Email" Keyboard="Email" />
            <Picker x:Name="UserTenantPicker" Title="Comedor (opcional)" />
            <Picker x:Name="UserRolePicker" Title="Rol en comedor" />
            <HorizontalStackLayout Spacing="8">
              <Label Text="Administrador global" VerticalOptions="Center" />
              <Switch x:Name="SystemAdminSwitch" />
            </HorizontalStackLayout>
            <Button Text="Crear usuario" Clicked="OnCreateUserClicked" />
            <Label x:Name="TempUserPasswordLabel" TextColor="{StaticResource ColorAccent}" IsVisible="False" />
          </VerticalStackLayout>
        </Frame>

        <CollectionView x:Name="UsersList" SelectionMode="None">
          <CollectionView.ItemTemplate>
            <DataTemplate>
              <Frame Margin="0,0,0,8">
                <VerticalStackLayout Spacing="6">
                  <Label Text="{Binding FullName}" FontAttributes="Bold" />
                  <Label Text="{Binding Email}" TextColor="{StaticResource ColorMuted}" />
                  <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Button Text="Bloquear" BackgroundColor="{StaticResource ColorDanger}" Clicked="OnBlockUserClicked" CommandParameter="{Binding .}" />
                    <Button Grid.Column="1" Text="Anonimizar" BackgroundColor="{StaticResource ColorSecondary}" Clicked="OnAnonymizeUserClicked" CommandParameter="{Binding .}" />
                    <Button Grid.Column="2" Text="Exportar" BackgroundColor="{StaticResource ColorPrimaryDark}" Clicked="OnExportUserClicked" CommandParameter="{Binding .}" />
                  </Grid>
                </VerticalStackLayout>
              </Frame>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Text="Audit Logs" FontSize="20" FontAttributes="Bold" />
        <CollectionView x:Name="AuditList" SelectionMode="None">
          <CollectionView.ItemTemplate>
            <DataTemplate>
              <Frame Margin="0,0,0,6" Padding="8">
                <VerticalStackLayout Spacing="3">
                  <Label Text="{Binding Action}" FontAttributes="Bold" />
                  <Label Text="{Binding EntityType}" FontSize="12" TextColor="{StaticResource ColorMuted}" />
                  <Label Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}" FontSize="12" TextColor="{StaticResource ColorMuted}" />
                </VerticalStackLayout>
              </Frame>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>
      </VerticalStackLayout>
    </ScrollView>
  </RefreshView>
</ContentPage>
