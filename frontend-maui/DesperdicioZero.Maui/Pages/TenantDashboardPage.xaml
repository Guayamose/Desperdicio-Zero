<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DesperdicioZero.Maui.Pages.TenantDashboardPage"
             Title="Dashboard">
  <RefreshView x:Name="RefreshControl" Refreshing="OnRefreshing">
    <ScrollView>
      <VerticalStackLayout Padding="16" Spacing="12">
        <Label x:Name="TenantLabel" FontSize="24" FontAttributes="Bold" />

        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
          <Frame Grid.Row="0" Grid.Column="0">
            <VerticalStackLayout>
              <Label Text="Stock actual" TextColor="{StaticResource ColorMuted}" />
              <Label x:Name="InventoryMetric" FontSize="26" FontAttributes="Bold" />
            </VerticalStackLayout>
          </Frame>
          <Frame Grid.Row="0" Grid.Column="1">
            <VerticalStackLayout>
              <Label Text="Críticos <48h" TextColor="{StaticResource ColorMuted}" />
              <Label x:Name="ExpiringMetric" FontSize="26" FontAttributes="Bold" TextColor="{StaticResource ColorDanger}" />
            </VerticalStackLayout>
          </Frame>
          <Frame Grid.Row="1" Grid.Column="0">
            <VerticalStackLayout>
              <Label Text="Menú hoy" TextColor="{StaticResource ColorMuted}" />
              <Label x:Name="TodayMenuMetric" FontSize="26" FontAttributes="Bold" />
            </VerticalStackLayout>
          </Frame>
          <Frame Grid.Row="1" Grid.Column="1">
            <VerticalStackLayout>
              <Label Text="Latencia IA" TextColor="{StaticResource ColorMuted}" />
              <Label x:Name="LatencyMetric" FontSize="26" FontAttributes="Bold" />
            </VerticalStackLayout>
          </Frame>
        </Grid>

        <Frame>
          <VerticalStackLayout Spacing="8">
            <Label Text="Menú de hoy" FontAttributes="Bold" FontSize="18" />
            <Label x:Name="TodayMenuTitle" FontAttributes="Bold" />
            <Label x:Name="TodayMenuDescription" TextColor="{StaticResource ColorMuted}" />
          </VerticalStackLayout>
        </Frame>
      </VerticalStackLayout>
    </ScrollView>
  </RefreshView>
</ContentPage>
