<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DesperdicioZero.Maui.Pages.ProfilePage"
             Title="Perfil">
  <ScrollView>
    <VerticalStackLayout Padding="16" Spacing="12">
      <Label Text="Mi Perfil" FontSize="24" FontAttributes="Bold" />

      <Frame>
        <VerticalStackLayout Spacing="8">
          <Label Text="Conexión" FontAttributes="Bold" FontSize="18" />
          <Entry x:Name="BaseUrlEntry" Placeholder="URL backend" />
          <Button Text="Actualizar URL" Clicked="OnUpdateBaseUrlClicked" BackgroundColor="{StaticResource ColorSecondary}" />
        </VerticalStackLayout>
      </Frame>

      <Frame>
        <VerticalStackLayout Spacing="8">
          <Label Text="Datos de usuario" FontAttributes="Bold" FontSize="18" />
          <Label x:Name="UserEmailLabel" TextColor="{StaticResource ColorMuted}" />
          <Entry x:Name="FullNameEntry" Placeholder="Nombre completo" />
          <Button Text="Guardar perfil" Clicked="OnSaveProfileClicked" />
        </VerticalStackLayout>
      </Frame>

      <Frame>
        <VerticalStackLayout Spacing="8">
          <Label Text="Cambiar contraseña" FontAttributes="Bold" FontSize="18" />
          <Entry x:Name="NewPasswordEntry" Placeholder="Nueva contraseña" IsPassword="True" />
          <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirmar contraseña" IsPassword="True" />
          <Button Text="Actualizar contraseña" Clicked="OnChangePasswordClicked" BackgroundColor="{StaticResource ColorAccent}" />
        </VerticalStackLayout>
      </Frame>

      <Frame>
        <VerticalStackLayout Spacing="8">
          <Label Text="Tenant activo" FontAttributes="Bold" FontSize="18" />
          <Picker x:Name="TenantPicker" ItemDisplayBinding="{Binding Label}" />
          <Button Text="Cambiar comedor" Clicked="OnSwitchTenantClicked" BackgroundColor="{StaticResource ColorSecondary}" />
        </VerticalStackLayout>
      </Frame>

      <Button Text="Cerrar sesión" BackgroundColor="{StaticResource ColorDanger}" Clicked="OnLogoutClicked" />
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
