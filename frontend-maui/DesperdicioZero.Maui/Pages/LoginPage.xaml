<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DesperdicioZero.Maui.Pages.LoginPage"
             Title="Acceso privado">
  <ScrollView>
    <VerticalStackLayout Padding="24" Spacing="14">
      <Image Source="logo-zero.png" HeightRequest="72" HorizontalOptions="Center" />
      <Label Text="Desperdicio Cero" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" />
      <Label Text="Accede al panel interno y administración" TextColor="{StaticResource ColorMuted}" HorizontalOptions="Center" />

      <Frame>
        <VerticalStackLayout Spacing="10">
          <Label Text="URL del backend Ruby" FontAttributes="Bold" />
          <Entry x:Name="BaseUrlEntry" Placeholder="http://localhost:3000" Keyboard="Url" />

          <Label Text="Email" FontAttributes="Bold" />
          <Entry x:Name="EmailEntry" Placeholder="usuario@dominio.com" Keyboard="Email" />

          <Label Text="Contraseña" FontAttributes="Bold" />
          <Entry x:Name="PasswordEntry" Placeholder="********" IsPassword="True" />

          <Button x:Name="LoginButton" Text="Entrar" Clicked="OnLoginClicked" />
          <Label x:Name="ErrorLabel" TextColor="{StaticResource ColorDanger}" IsVisible="False" />
        </VerticalStackLayout>
      </Frame>

      <Label Text="Tip Android Emulator: usa 10.0.2.2 en vez de localhost." FontSize="12" TextColor="{StaticResource ColorMuted}" />
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
