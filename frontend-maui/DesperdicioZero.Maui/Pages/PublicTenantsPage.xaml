<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DesperdicioZero.Maui.Pages.PublicTenantsPage"
             Title="Comedores públicos">
  <RefreshView x:Name="RefreshControl" Refreshing="OnRefreshing">
    <ScrollView>
      <VerticalStackLayout Padding="16" Spacing="12">
        <Label Text="Directorio de Comedores" FontSize="24" FontAttributes="Bold" />
        <Entry x:Name="SearchEntry" Placeholder="Buscar por ciudad o nombre..." TextChanged="OnSearchChanged" />

        <CollectionView x:Name="TenantsList" SelectionMode="None">
          <CollectionView.ItemTemplate>
            <DataTemplate>
              <Frame Margin="0,0,0,8">
                <VerticalStackLayout Spacing="8">
                  <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                  <Label Text="{Binding City}" TextColor="{StaticResource ColorMuted}" />
                  <Label Text="{Binding Status}" TextColor="{StaticResource ColorSecondary}" />
                  <Button Text="Ver Menú de Hoy" Clicked="OnOpenMenuClicked" CommandParameter="{Binding .}" />
                </VerticalStackLayout>
              </Frame>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>

        <Frame x:Name="MenuFrame" IsVisible="False">
          <VerticalStackLayout Spacing="8">
            <Label x:Name="MenuTenantLabel" FontAttributes="Bold" FontSize="18" />
            <Label x:Name="MenuTitleLabel" FontAttributes="Bold" />
            <Label x:Name="MenuDescriptionLabel" TextColor="{StaticResource ColorMuted}" />
            <CollectionView x:Name="MenuItemsList">
              <CollectionView.ItemTemplate>
                <DataTemplate>
                  <Frame Padding="8" Margin="0,0,0,6">
                    <VerticalStackLayout Spacing="4">
                      <Label Text="{Binding Name}" FontAttributes="Bold" />
                      <Label Text="{Binding Description}" FontSize="12" TextColor="{StaticResource ColorMuted}" />
                    </VerticalStackLayout>
                  </Frame>
                </DataTemplate>
              </CollectionView.ItemTemplate>
            </CollectionView>
          </VerticalStackLayout>
        </Frame>
      </VerticalStackLayout>
    </ScrollView>
  </RefreshView>
</ContentPage>
