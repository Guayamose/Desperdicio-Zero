<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
  <Style TargetType="ContentPage">
    <Setter Property="BackgroundColor" Value="{StaticResource ColorBackground}" />
  </Style>

  <Style TargetType="Label">
    <Setter Property="TextColor" Value="{StaticResource ColorText}" />
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style TargetType="Button">
    <Setter Property="BackgroundColor" Value="{StaticResource ColorPrimary}" />
    <Setter Property="TextColor" Value="White" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="FontAttributes" Value="Bold" />
  </Style>

  <Style TargetType="Entry">
    <Setter Property="BackgroundColor" Value="White" />
    <Setter Property="TextColor" Value="{StaticResource ColorText}" />
    <Setter Property="HeightRequest" Value="44" />
  </Style>

  <Style TargetType="Picker">
    <Setter Property="BackgroundColor" Value="White" />
    <Setter Property="TextColor" Value="{StaticResource ColorText}" />
  </Style>

  <Style TargetType="Editor">
    <Setter Property="BackgroundColor" Value="White" />
    <Setter Property="TextColor" Value="{StaticResource ColorText}" />
    <Setter Property="AutoSize" Value="TextChanges" />
    <Setter Property="HeightRequest" Value="90" />
  </Style>

  <Style TargetType="Frame">
    <Setter Property="BackgroundColor" Value="{StaticResource ColorSurface}" />
    <Setter Property="BorderColor" Value="{StaticResource ColorLine}" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="HasShadow" Value="False" />
    <Setter Property="Padding" Value="14" />
  </Style>
</ResourceDictionary>
