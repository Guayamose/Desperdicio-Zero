<section class="page-header">
  <div>
    <h1 class="page-title">Usuarios</h1>
    <p class="page-subtitle">Gestion de cuentas internas, bloqueos y roles de administracion.</p>
  </div>
  <div class="toolbar">
    <%= link_to "Crear usuario", new_admin_user_path, class: "btn btn-primary btn-sm" %>
  </div>
</section>

<section class="panel panel-soft">
  <div class="table-shell">
    <table>
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Email</th>
          <th>Bloqueado</th>
          <th>Admin global</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td data-label="Nombre"><strong><%= user.full_name %></strong></td>
            <td data-label="Email"><span style="word-break: break-all;"><%= user.email %></span></td>
            <td data-label="Bloqueado"><%= status_pill(user.blocked_at.present? ? "blocked" : "active") %></td>
            <td data-label="Admin"><%= status_pill(user.system_admin? ? "system_admin" : "inactive") %></td>
            <td data-label="">
              <%= link_to "Ver", admin_user_path(user), class: "btn btn-secondary btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
