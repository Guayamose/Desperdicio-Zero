<% content_for :head do %>
  <style>
    /* Premium Admin Metrics styles */
    .admin-metrics-hero {
      background: linear-gradient(135deg, #0f172a 0%, #172554 100%);
      border-radius: 28px;
      padding: 4rem 3rem;
      margin-bottom: 3rem;
      color: white;
      position: relative;
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }
    
    .admin-metrics-hero::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(99,102,241,0.15) 0%, transparent 60%);
      pointer-events: none;
    }

    .admin-metrics-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      position: relative;
      z-index: 2;
    }

    .admin-metrics-title {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      font-weight: 800;
      letter-spacing: -0.04em;
      margin: 0.5rem 0 1rem;
      background: linear-gradient(to right, #fff, #94a3b8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1.1;
    }

    .admin-metrics-breadcrumb {
      font-size: 0.875rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #818cf8;
      font-weight: 800;
    }
    
    .admin-metrics-toolbar {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .admin-btn-glass {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: white;
      padding: 0.875rem 1.5rem;
      border-radius: 14px;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .admin-btn-glass:hover {
      background: rgba(255, 255, 255, 0.2);
      transform: translateY(-4px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.15);
      border-color: rgba(255,255,255,0.4);
    }

    .premium-metric-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
      margin-bottom: 4rem;
    }

    .premium-metric-card {
      background: white;
      border-radius: 24px;
      padding: 2rem;
      border: 1px solid var(--line-light, #e2e8f0);
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -1px rgba(0, 0, 0, 0.02);
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      position: relative;
      overflow: hidden;
    }

    .premium-metric-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
      border-color: #cbd5e1;
    }

    .premium-metric-card::after {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 150px;
      height: 150px;
      background: radial-gradient(circle, var(--accent-color, rgba(99,102,241,0.05)) 0%, transparent 70%);
      border-radius: 50%;
      transform: translate(30%, -30%);
      pointer-events: none;
    }

    .metric-icon-box {
      width: 52px;
      height: 52px;
      border-radius: 16px;
      background: var(--icon-bg, #f1f5f9);
      color: var(--icon-color, #64748b);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.75rem;
    }

    .pm-label {
      font-size: 0.875rem;
      font-weight: 800;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.5rem;
    }

    .pm-value {
      font-family: 'Outfit', sans-serif;
      font-size: 3rem;
      font-weight: 800;
      color: #0f172a;
      line-height: 1;
      margin-bottom: 1.25rem;
      letter-spacing: -0.02em;
    }

    .pm-caption {
      font-size: 0.8125rem;
      color: #94a3b8;
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-weight: 500;
    }

    .admin-dashboard-split {
      display: grid;
      grid-template-columns: 3fr 2fr;
      gap: 2rem;
    }
    
    @media (max-width: 1024px) {
      .admin-dashboard-split { grid-template-columns: 1fr; }
      .admin-metrics-header { flex-direction: column; align-items: flex-start; gap: 2.5rem; }
    }

    .admin-panel {
      background: white;
      border-radius: 28px;
      padding: 2.5rem;
      border: 1px solid var(--line-light, #e2e8f0);
      box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }

    .admin-panel h2 {
      font-family: 'Outfit', sans-serif;
      font-size: 1.5rem;
      font-weight: 800;
      margin-bottom: 2rem;
      color: #1e293b;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      letter-spacing: -0.01em;
    }

    .distribution-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .dist-row {
      display: grid;
      grid-template-columns: 160px 1fr 60px;
      align-items: center;
      gap: 1rem;
    }

    @media (max-width: 640px) {
      .dist-row { grid-template-columns: 100px 1fr 50px; }
      .dist-label { font-size: 0.875rem !important; }
    }

    .dist-label {
      font-size: 0.9375rem;
      font-weight: 600;
      color: #475569;
    }

    .dist-bar-bg {
      height: 10px;
      background: #f1f5f9;
      border-radius: 99px;
      overflow: hidden;
      width: 100%;
    }

    .dist-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, #6366f1, #c084fc);
      border-radius: 99px;
      animation: fillBar 1.2s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
      transform-origin: left;
    }

    @keyframes fillBar {
      0% { transform: scaleX(0); }
      100% { transform: scaleX(1); }
    }

    .dist-value {
      font-family: 'Outfit', sans-serif;
      font-weight: 800;
      color: #0f172a;
      text-align: right;
      font-size: 1.125rem;
    }

    .quick-read-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .quick-read-item {
      display: flex;
      gap: 1.25rem;
      padding: 1.25rem;
      background: #f8fafc;
      border-radius: 20px;
      transition: all 0.3s ease;
      border: 1px solid transparent;
    }

    .quick-read-item:hover {
      background: white;
      border-color: #e2e8f0;
      box-shadow: 0 10px 20px rgba(0,0,0,0.05);
      transform: translateX(4px);
    }

    .qr-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .qr-content strong {
      display: block;
      font-size: 1.05rem;
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 0.35rem;
    }

    .qr-content p {
      margin: 0;
      font-size: 0.875rem;
      color: #64748b;
      line-height: 1.6;
    }
  </style>
<% end %>

<%
  # Helper for mapping metrics to icons and colors
  def metric_visuals(key)
    case key.to_sym
    when :tenants, :active_tenants
      { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 21h18"/><path d="M9 8h1M9 12h1M9 16h1M14 8h1M14 12h1M14 16h1"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>', color: '#3b82f6', bg: '#eff6ff' }
    when :users
      { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>', color: '#8b5cf6', bg: '#f5f3ff' }
    when :blocked_users
      { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>', color: '#ef4444', bg: '#fef2f2' }
    when :lots, :expired_lots
      { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>', color: '#f59e0b', bg: '#fffbeb' }
    when :menu_fallbacks
      { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m19 11-8-8-8.6 8.6a2 2 0 0 0 0 2.8l5.2 5.2c.8.8 2 .8 2.8 0L19 11Z"/><path d="m5 2 5 5"/></svg>', color: '#10b981', bg: '#ecfdf5' }
    else
      { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>', color: '#64748b', bg: '#f8fafc' }
    end
  end
%>

<section class="admin-metrics-hero">
  <div class="admin-metrics-header">
    <div>
      <p class="admin-metrics-breadcrumb">Administración Global</p>
      <h1 class="admin-metrics-title">Métricas de la Plataforma</h1>
      <p style="color: #cbd5e1; font-size: 1.125rem; max-width: 650px; margin: 0; line-height: 1.6;">
        Visibilidad en tiempo real del estado operativo, seguridad e inventario en toda la red de sociales de Desperdicio Zero.
      </p>
    </div>
    <div class="admin-metrics-toolbar">
      <%= link_to(admin_tenants_path, class: "admin-btn-glass") do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18"/><path d="M9 8h1M9 12h1M9 16h1M14 8h1M14 12h1M14 16h1"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>
        Comedores
      <% end %>
      <%= link_to(admin_users_path, class: "admin-btn-glass") do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Usuarios
      <% end %>
      <%= link_to(admin_audit_logs_path, class: "admin-btn-glass") do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Auditoría
      <% end %>
    </div>
  </div>
</section>

<section class="premium-metric-grid">
  <% @metrics.each do |key, value| %>
    <% visual = metric_visuals(key) %>
    <article class="premium-metric-card" style="--accent-color: <%= visual[:bg] %>; --icon-color: <%= visual[:color] %>; --icon-bg: <%= visual[:bg] %>;">
      <div class="metric-icon-box">
        <%= visual[:icon].html_safe %>
      </div>
      <div class="pm-label"><%= key.to_s.humanize %></div>
      <div class="pm-value"><%= number_with_delimiter(value) %></div>
      <div class="pm-caption">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21.5 2v6h-6M2.13 15.57a10 10 0 1 0 4.43-10"/><path d="M22 22 12 12"/></svg>
        Actualizado <%= time_ago_in_words(Time.current) %>
      </div>
    </article>
  <% end %>
</section>

<div class="admin-dashboard-split">
  <article class="admin-panel">
    <h2>
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2.5"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
      Distribución Relativa
    </h2>
    <% max_value = @metrics.values.max.to_f.nonzero? || 1.0 %>
    <div class="distribution-list">
      <% @metrics.sort_by { |_, v| -v }.each do |key, value| %>
        <% pct = (value.to_f / max_value * 100).round(1) %>
        <div class="dist-row">
          <div class="dist-label"><%= key.to_s.humanize %></div>
          <div class="dist-bar-bg">
            <div class="dist-bar-fill" style="width: <%= pct %>%;"></div>
          </div>
          <div class="dist-value"><%= number_with_delimiter(value) %></div>
        </div>
      <% end %>
    </div>
  </article>

  <article class="admin-panel">
    <h2>
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
      Lectura Rápida
    </h2>
    <ul class="quick-read-list">
      <li class="quick-read-item">
        <div class="qr-icon" style="background: #eff6ff; color: #3b82f6;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="qr-content">
          <strong>Tenants activos</strong>
          <p><%= @metrics[:active_tenants] || 0 %> de <%= @metrics[:tenants] || 0 %> en estado operativo para la gestión diaria y publicacion de menus.</p>
        </div>
      </li>
      <li class="quick-read-item">
        <div class="qr-icon" style="background: #fef2f2; color: #ef4444;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </div>
        <div class="qr-content">
          <strong>Usuarios bloqueados</strong>
          <p><%= @metrics[:blocked_users] || 0 %> cuentas marcadas actualmente preventivamente para revisión por administradores globales.</p>
        </div>
      </li>
      <li class="quick-read-item">
        <div class="qr-icon" style="background: #fffbeb; color: #f59e0b;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="qr-content">
          <strong>Salud de inventario</strong>
          <p><%= @metrics[:expired_lots] || 0 %> lotes vencidos registrados a través de todos los comedores. Requieren depuración para evitar desperdicio.</p>
        </div>
      </li>
      <li class="quick-read-item">
        <div class="qr-icon" style="background: #ecfdf5; color: #10b981;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        </div>
        <div class="qr-content">
          <strong>Fallbacks de menú IA</strong>
          <p><%= @metrics.fetch(:menu_fallbacks, 0) %> eventos detectados en los últimos días debido a errores o timeouts de la IA central.</p>
        </div>
      </li>
    </ul>
  </article>
</div>
