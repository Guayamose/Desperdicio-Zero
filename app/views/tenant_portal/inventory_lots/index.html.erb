<section class="page-header">
  <div>
    <span class="eyebrow">Gestión de Almacén</span>
    <h1 class="page-title">Inventario de Lotes</h1>
    <p class="page-subtitle">Control de stock detallado por lote y fechas de caducidad crítitcas.</p>
  </div>
  <div class="toolbar">
    <%= link_to new_tenant_inventory_lot_path, class: "btn btn-primary" do %>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      Nuevo Lote
    <% end %>
    <%= link_to "Escanear", new_tenant_scan_path, class: "btn btn-secondary" %>
  </div>
</section>

<turbo-frame id="inventory_lots_panel" data-turbo-action="replace">
  <section class="panel" data-controller="card-filter" style="padding: 1.5rem;">
    <div class="field" style="margin-bottom: 2rem;">
      <label for="inventory-filter" style="font-size: 0.75rem; color: var(--text-muted);">Filtrar por producto, lote o estado</label>
      <div style="position: relative;">
        <input id="inventory-filter" type="search" placeholder="Buscar en inventario..." data-card-filter-target="query" data-action="input->card-filter#filter" style="padding-left: 2.5rem;">
        <svg style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </div>
    </div>

    <div class="table-shell">
      <table>
        <thead>
          <tr>
            <th><%= sort_link("Producto", "product") %></th>
            <th><%= sort_link("Cantidad", "quantity") %></th>
            <th><%= sort_link("Vence el", "expires_on") %></th>
            <th><%= sort_link("Estado", "status") %></th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @inventory_lots.each do |lot| %>
            <tr data-card-filter-target="card" data-search="<%= [lot.product.name, lot.status, lot.unit, lot.source].join(' ') %>">
              <td data-label="Producto">
                <div>
                  <div style="font-weight: 700; color: var(--text);"><%= lot.product.name %></div>
                  <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">LOTE #<%= lot.id %> • <%= lot.source.upcase %></div>
                </div>
              </td>
              <td data-label="Cantidad">
                <span style="font-weight: 600; font-size: 1rem;"><%= lot.quantity %></span>
                <span style="font-size: 0.8rem; color: var(--text-muted);"><%= lot.unit %></span>
              </td>
              <td data-label="Vence el">
                <div style="font-weight: 500; <%= 'color: var(--danger);' if lot.expires_on <= Date.today + 2.days %>">
                  <%= ui_date(lot.expires_on) %>
                </div>
              </td>
              <td data-label="Estado"><%= status_pill(lot.status) %></td>
              <td data-label="">
                <div class="actions" style="justify-content: flex-end; margin-top: 0;">
                  <%= link_to "Ver", tenant_inventory_lot_path(lot), class: "btn btn-secondary btn-sm", data: { turbo_frame: "_top" } %>
                  <%= link_to "Editar", edit_tenant_inventory_lot_path(lot), class: "btn btn-secondary btn-sm", data: { turbo_frame: "_top" } %>
                  <%= button_to tenant_inventory_lot_path(lot), method: :delete, data: { turbo_confirm: "Eliminar lote?", turbo_frame: "_top" }, class: "btn btn-sm", style: "background: transparent; border: none; color: var(--danger);" do %>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="empty-state is-hidden" data-card-filter-target="empty" style="margin-top: 2rem;">
      Ningún lote coincide con la búsqueda.
    </div>
  </section>
</turbo-frame>
