<section class="page-header">
  <div>
    <h1 class="page-title">Centro de Alertas</h1>
    <p class="page-subtitle">Priorización y gestión de inventario en riesgo.</p>
  </div>
  <div class="toolbar">
    <%= link_to "Ver Inventario Completo", tenant_inventory_lots_path, class: "btn btn-secondary" %>
  </div>
</section>

<div class="metric-grid" style="margin-bottom: 2rem;">
  <div class="metric-card" style="border-left: 4px solid var(--accent); background: linear-gradient(to right, var(--accent-soft) 0%, var(--surface) 20%);">
    <div class="metric-label" style="color: var(--accent); text-transform: uppercase; font-weight: 800; font-size: 0.75rem;">Atención Requerida</div>
    <div class="metric-value"><%= @expiring_lots.count %></div>
    <div class="metric-caption">Lotes que caducan en menos de 48 horas</div>
  </div>

  <div class="metric-card" style="border-left: 4px solid var(--danger); background: linear-gradient(to right, var(--danger-soft) 0%, var(--surface) 20%);">
    <div class="metric-label" style="color: var(--danger); text-transform: uppercase; font-weight: 800; font-size: 0.75rem;">Acción Inmediata</div>
    <div class="metric-value"><%= @expired_lots.count %></div>
    <div class="metric-caption">Lotes vencidos actualmente en stock</div>
  </div>
</div>

<section class="alerts-panels">
  <article class="alert-panel">
    <div class="alert-panel-header">
      <h2 class="alert-panel-title">Caducan en 48h</h2>
      <span class="status-pill status-warning">Alta Prioridad</span>
    </div>

    <% if @expiring_lots.any? %>
      <div class="alert-items-list">
        <% @expiring_lots.each do |lot| %>
          <div class="alert-item alert-item-warning">
            <div class="alert-item-main">
              <span class="alert-item-name"><%= lot.product.name %></span>
              <span class="alert-item-qty"><%= lot.quantity %> <small><%= lot.unit %></small></span>
            </div>
            <div class="alert-item-meta">
              <span class="alert-item-date">Vence: <%= ui_date(lot.expires_on) %></span>
              <%= status_pill(lot.status) %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state" style="background: var(--surface); border: 1px dashed var(--line); border-radius: var(--radius-lg); padding: 3rem 2rem;">
        <p style="margin: 0; font-weight: 700; font-size: 1.1rem;">Inventario saludable</p>
        <span style="font-size: 0.9rem; color: var(--text-muted);">No hay lotes próximos a caducar.</span>
      </div>
    <% end %>
  </article>

  <article class="alert-panel">
    <div class="alert-panel-header">
      <h2 class="alert-panel-title">Lotes Vencidos</h2>
      <span class="status-pill status-danger">Crítico</span>
    </div>

    <% if @expired_lots.any? %>
      <div class="alert-items-list">
        <% @expired_lots.each do |lot| %>
          <div class="alert-item alert-item-danger">
            <div class="alert-item-main">
              <span class="alert-item-name" style="color: var(--danger);"><%= lot.product.name %></span>
              <span class="alert-item-qty" style="color: var(--danger);"><%= lot.quantity %> <small><%= lot.unit %></small></span>
            </div>
            <div class="alert-item-meta">
              <span class="alert-item-date" style="color: var(--danger); opacity: 0.8;">Venció: <%= ui_date(lot.expires_on) %></span>
              <%= status_pill("expired") %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state" style="background: var(--surface); border: 1px dashed var(--line); border-radius: var(--radius-lg); padding: 3rem 2rem;">
        <p style="margin: 0; font-weight: 700; font-size: 1.1rem;">Todo optimizado</p>
        <span style="font-size: 0.9rem; color: var(--text-muted);">No hay lotes vencidos en el sistema.</span>
      </div>
    <% end %>
  </article>
</section>
