<section class="menu-summary-hero">
  <div>
    <p class="eyebrow">Resumen del dia <%= ui_date(@menu.menu_date) %></p>
    <h1 class="page-title"><%= @menu.title %></h1>
    <p class="page-subtitle">Valida platos y alergenos antes de confirmar publicacion.</p>
    <div class="menu-summary-badges">
      <%= status_pill(@menu.status) %>
      <%= status_pill(@menu.generated_by) %>
    </div>
  </div>
  <div class="toolbar">
    <%= link_to "Volver al historial", tenant_menus_path, class: "btn btn-secondary" %>
    <%= link_to "Editar", edit_tenant_menu_path(@menu), class: "btn btn-secondary" %>
  </div>
</section>

<% if @menu.draft? %>
  <section class="menu-lock-banner">
    <div>
      <h2>Preview pendiente de confirmacion</h2>
      <p>Este menu aun no es visible en publico. Revisa el contenido y confirma para publicarlo en todos los canales.</p>
    </div>
    <div class="actions">
      <%= button_to publish_tenant_menu_path(@menu), method: :post, class: "btn btn-primary" do %>
        Confirmar y Publicar
      <% end %>
      <%= button_to tenant_menu_path(@menu),
        method: :delete,
        class: "btn btn-danger",
        form: { data: { turbo_confirm: "Eliminar este menu borrador? Esta accion no se puede deshacer." } } do %>
        Eliminar menu
      <% end %>
    </div>
  </section>
<% end %>

<section class="menu-summary-grid">
  <article class="panel">
    <div class="menu-flow-panel-head">
      <h2>Platos del menu</h2>
      <span class="status-pill status-neutral"><%= @menu.daily_menu_items.size %> platos</span>
    </div>

    <% if @menu.daily_menu_items.any? %>
      <div class="menu-dishes-grid">
        <% @menu.daily_menu_items.each do |item| %>
          <article class="menu-dish-card">
            <h3><%= item.name %></h3>
            <p><%= present_or_dash(item.description) %></p>

            <% if item.ingredients_json.present? %>
              <div class="menu-chip-group">
                <% Array(item.ingredients_json).each do |ingredient| %>
                  <span class="menu-chip"><%= ingredient %></span>
                <% end %>
              </div>
            <% end %>

            <% if item.allergens_json.present? %>
              <div class="menu-chip-group">
                <% Array(item.allergens_json).each do |allergen| %>
                  <span class="menu-chip menu-chip-danger"><%= allergen %></span>
                <% end %>
              </div>
            <% end %>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">No hay platos registrados en este menu.</div>
    <% end %>
  </article>

  <aside class="panel panel-soft menu-sticky-preview">
    <h3>Control de calidad</h3>
    <p class="help-text"><strong>Descripcion:</strong> <%= present_or_dash(@menu.description) %></p>

    <div class="menu-summary-checklist">
      <div class="menu-check-row">
        <span>Titulo definido</span>
        <strong><%= @menu.title.present? ? "OK" : "Falta" %></strong>
      </div>
      <div class="menu-check-row">
        <span>Platos cargados</span>
        <strong><%= @menu.daily_menu_items.any? ? "OK" : "Falta" %></strong>
      </div>
      <div class="menu-check-row">
        <span>Alergenos globales</span>
        <strong><%= @menu.allergens_json.present? ? "Informados" : "Sin datos" %></strong>
      </div>
    </div>

    <% if @menu.allergens_json.present? %>
      <h4 class="menu-mini-title">Alergenos generales</h4>
      <div class="menu-chip-group">
        <% Array(@menu.allergens_json).each do |allergen| %>
          <span class="menu-chip menu-chip-danger"><%= allergen %></span>
        <% end %>
      </div>
    <% end %>

    <% if @menu.draft? %>
      <div class="actions mt-sm">
        <%= button_to publish_tenant_menu_path(@menu), method: :post, class: "btn btn-primary menu-cta" do %>
          Confirmar y Publicar
        <% end %>
        <%= button_to tenant_menu_path(@menu),
          method: :delete,
          class: "btn btn-danger menu-cta",
          form: { data: { turbo_confirm: "Eliminar este menu borrador? Esta accion no se puede deshacer." } } do %>
          Eliminar menu
        <% end %>
      </div>
    <% end %>
  </aside>
</section>
