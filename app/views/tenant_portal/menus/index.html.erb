<section class="page-header">
  <div>
    <span class="eyebrow">Gestión de Cocina</span>
    <h1 class="page-title">Historial de Menús</h1>
    <p class="page-subtitle">Gestiona borradores, publicaciones y generacion automatica con IA.</p>
  </div>
  <div class="toolbar">
    <%= link_to generate_tenant_menus_path(date: Date.current), class: "btn btn-primary" do %>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4m0 14v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m14 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83M12 7a5 5 0 015 5 5 5 0 01-5 5 5 5 0 01-5-5 5 5 0 015-5z"></path></svg>
      Generador IA
    <% end %>
    <%= link_to "Nuevo Menú Manual", new_tenant_menu_path, class: "btn btn-secondary" %>
  </div>
</section>

<section class="panel" data-controller="card-filter" style="padding: 1.5rem;">
  <div class="field" style="margin-bottom: 2rem; max-width: 400px;">
    <label for="menu-filter" style="font-size: 0.75rem; color: var(--text-muted);">Filtrar por título, estado u origen</label>
    <div style="position: relative;">
      <input id="menu-filter" type="search" placeholder="Buscar..." data-card-filter-target="query" data-action="input->card-filter#filter" style="padding-left: 2.5rem;">
      <svg style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
    </div>
  </div>

  <div class="table-shell">
    <table>
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Título del Menú</th>
          <th>Estado</th>
          <th>Origen</th>
          <th style="text-align: right;">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @menus.each do |menu| %>
          <tr data-card-filter-target="card" data-search="<%= [menu.title, menu.status, menu.generated_by].join(' ') %>">
            <td style="white-space: nowrap; font-weight: 500;"><%= ui_date(menu.menu_date) %></td>
            <td>
              <strong><%= menu.title %></strong>
              <div style="font-size: 0.8rem; color: var(--text-muted);"><%= truncate(menu.description, length: 60) %></div>
            </td>
            <td><%= status_pill(menu.status) %></td>
            <td><%= status_pill(menu.generated_by) %></td>
            <td style="text-align: right;">
              <div class="actions" style="justify-content: flex-end; margin-top: 0;">
                <%= link_to "Ver", tenant_menu_path(menu), class: "btn btn-secondary btn-sm" %>
                <%= link_to "Editar", edit_tenant_menu_path(menu), class: "btn btn-secondary btn-sm" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="empty-state is-hidden" data-card-filter-target="empty" style="margin-top: 2rem;">
    Ningún menú coincide con la búsqueda.
  </div>
</section>
