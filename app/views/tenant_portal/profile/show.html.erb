<%# Hero del perfil %>
<section class="profile-hero">
  <div class="profile-hero-body">
    <div class="profile-avatar-lg">
      <%= current_user.full_name.split.map(&:first).first(2).join.upcase %>
    </div>
    <div class="profile-hero-info">
      <h1 class="profile-hero-name"><%= current_user.full_name %></h1>
      <p class="profile-hero-email">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
        <%= current_user.email %>
      </p>
      <% if current_tenant.present? %>
        <% membership = current_user.active_memberships.find_by(tenant_id: current_tenant.id) %>
        <% if membership %>
          <div class="profile-hero-role">
            <%= status_pill(membership.role) %>
            <span class="profile-hero-tenant">en <%= current_tenant.name %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="profile-hero-actions">
    <%= link_to edit_tenant_profile_path, class: "btn btn-secondary btn-sm" do %>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path></svg>
      Editar perfil
    <% end %>
  </div>
</section>

<div class="profile-content-grid">
  <%# Columna izquierda: Stats %>
  <div class="profile-stats-grid">
    <div class="profile-stat-card">
      <div class="profile-stat-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
      </div>
      <div class="profile-stat-content">
        <div class="profile-stat-label">Miembro desde</div>
        <div class="profile-stat-value"><%= ui_date(current_user.created_at) %></div>
      </div>
    </div>

    <div class="profile-stat-card">
      <div class="profile-stat-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
      </div>
      <div class="profile-stat-content">
        <div class="profile-stat-label">Último acceso</div>
        <div class="profile-stat-value"><%= ui_datetime(current_user.last_seen_at) %></div>
      </div>
    </div>

    <div class="profile-stat-card">
      <div class="profile-stat-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
      </div>
      <div class="profile-stat-content">
        <div class="profile-stat-label">Comedores activos</div>
        <div class="profile-stat-value profile-stat-number"><%= current_user.active_memberships.count %></div>
      </div>
    </div>
  </div>

  <%# Columna derecha: Comedores %>
  <div>
    <% if current_user.active_memberships.any? %>
      <section class="panel">
        <div class="profile-section-head">
          <h2>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            Mis comedores
          </h2>
          <span class="profile-section-count"><%= current_user.active_memberships.count %></span>
        </div>
        <div class="profile-memberships">
          <% current_user.active_memberships.each do |membership| %>
            <% is_current = current_tenant.present? && membership.tenant_id == current_tenant.id %>
            <div class="profile-membership-row <%= 'is-current' if is_current %>">
              <div class="profile-membership-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"></path><path d="M7 2v20"></path><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"></path></svg>
              </div>
              <div class="profile-membership-info">
                <div class="profile-membership-name">
                  <%= membership.tenant.name %>
                  <% if is_current %>
                    <span class="profile-membership-current-tag">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      Activo
                    </span>
                  <% end %>
                </div>
                <div class="profile-membership-meta">
                  Unido el <%= ui_date(membership.created_at) %>
                </div>
              </div>
              <div class="profile-membership-actions">
                <%= status_pill(membership.role) %>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>
