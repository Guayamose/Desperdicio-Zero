<% content_for :hero do %>
<header class="portal-hero">
  <div class="container">
    <div style="max-width: 800px;">
      <span class="eyebrow" style="color: var(--primary); font-weight: 800; letter-spacing: 0.2em;">BIENVENIDO AL PORTAL DE SOLIDARIDAD</span>
      <h1 class="portal-hero-heading">Alimentos con propósito.</h1>
      <p class="portal-hero-subtitle">
        Gestionamos el excedente alimentario para garantizar que cada plato llegue a quien más lo necesita.
      </p>
    </div>

    <div class="onboarding-steps">
      <article class="step-card">
        <div class="step-number">1</div>
        <h3 style="color: white; margin-bottom: 0.5rem;">Explora Centros</h3>
        <p style="color: rgba(255,255,255,0.6); font-size: 0.9rem;">Encuentra el comedor más cercano a tu ubicación filtrando por ciudad o zona operativa.</p>
      </article>

      <article class="step-card">
        <div class="step-number">2</div>
        <h3 style="color: white; margin-bottom: 0.5rem;">Consulta el Menú</h3>
        <p style="color: rgba(255,255,255,0.6); font-size: 0.9rem;">Revisa en tiempo real los platos publicados por nuestros centros y sus alérgenos.</p>
      </article>

      <article class="step-card">
        <div class="step-number">3</div>
        <h3 style="color: white; margin-bottom: 0.5rem;">Accede y Colabora</h3>
        <p style="color: rgba(255,255,255,0.6); font-size: 0.9rem;">Obtén direcciones exactas y horarios de apertura para acudir o entregar donaciones.</p>
      </article>
    </div>
  </div>
</header>
<% end %>

<section class="container" style="margin-top: 4rem;">
  <div class="section-header-row">
    <div>
      <span class="eyebrow" style="color: var(--primary);">LO QUE SE COCINA HOY</span>
      <h2 class="section-heading">Menús Destacados</h2>
    </div>
    <%= link_to public_tenants_path, class: "btn btn-secondary" do %>
      Ver todos los comedores
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
    <% end %>
  </div>

  <div class="menu-carousel-wrapper">
    <div class="menu-carousel">
      <% if @menus_today.any? %>
        <div class="carousel-track">
          <%# Render twice for a seamless infinite loop %>
          <% 2.times do %>
            <% @menus_today.each do |menu| %>
              <div class="carousel-item">
                <div class="carousel-tenant-info">
                  <div class="carousel-tenant-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"></path><path d="M7 2v20"></path><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"></path></svg>
                  </div>
                  <div>
                    <span style="font-size: 0.65rem; text-transform: uppercase; font-weight: 800; color: var(--primary); letter-spacing: 0.05em; display: block;">ORIGEN</span>
                    <h4 style="margin: 0; font-size: 0.875rem; color: var(--text);"><%= menu.tenant.name %></h4>
                  </div>
                </div>
                
                <h3 class="carousel-dish-title"><%= menu.title %></h3>
                
                <p class="carousel-description">
                  <%= truncate(menu.description, length: 110, separator: ' ') %>
                </p>
                
                <div class="carousel-actions">
                  <%= link_to public_tenant_menu_today_path(slug: menu.tenant.slug), class: "btn btn-primary", style: "flex: 1; justify-content: center; height: 44px; font-weight: 700; font-size: 0.875rem;" do %>
                    <span>Ver Menú</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
                  <% end %>
                  
                  <%= link_to public_tenant_path(menu.tenant.slug), class: "btn btn-secondary", style: "width: 44px; height: 44px; padding: 0; justify-content: center;", title: "Info Comedor" do %>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state" style="width: 100%; min-height: 180px; background: white;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="margin-bottom: 0.75rem; opacity: 0.3;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          <p style="font-size: 0.875rem;">No se han publicado menús hoy en tu zona.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>

