<div data-controller="card-filter">
  <header style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; justify-content: space-between; padding: 1rem 0; margin-bottom: 1rem; border-bottom: 1px solid var(--border);">
    <div>
      <h1 style="font-family: 'Outfit', sans-serif; font-size: 1.25rem; font-weight: 700; margin: 0; color: var(--text);">Directorio de Comedores Sociales</h1>
      <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0.1rem 0 0 0;">Ayuda alimentaria más cercana.</p>
    </div>

    <div style="display: flex; flex-direction: column; gap: 0.5rem; flex: 1; max-width: 400px; min-width: 250px;">
      <div style="position: relative; width: 100%;">
        <svg style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input
          type="search"
          placeholder="Ciudad o nombre..."
          data-card-filter-target="query"
          data-action="input->card-filter#filter"
          id="kitchen-main-search"
          autocomplete="off"
          style="width: 100%; padding: 0.4rem 2rem; font-size: 0.85rem; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; color: var(--text); outline: none; transition: border-color 0.2s;"
        >
        <button type="button" data-action="click->card-filter#clear" style="display: none; position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 0.25rem;" id="search-clear-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      
      <div style="display: flex; gap: 0.3rem; flex-wrap: wrap;">
        <button class="suggest-chip" style="padding: 0.1rem 0.4rem; font-size: 0.7rem; border-radius: 4px;" data-action="click->card-filter#suggest" data-value="Madrid">Madrid</button>
        <button class="suggest-chip" style="padding: 0.1rem 0.4rem; font-size: 0.7rem; border-radius: 4px;" data-action="click->card-filter#suggest" data-value="Valencia">Valencia</button>
        <button class="suggest-chip" style="padding: 0.1rem 0.4rem; font-size: 0.7rem; border-radius: 4px;" data-action="click->card-filter#suggest" data-value="Barcelona">Barcelona</button>
        <button class="suggest-chip" style="padding: 0.1rem 0.4rem; font-size: 0.7rem; border-radius: 4px;" data-action="click->card-filter#suggest" data-value="active">Activos</button>
      </div>
    </div>
  </header>

  <div class="container main-shell">
    <% if @tenants.any? %>
      <div class="kitchen-grid">
        <% @tenants.each do |tenant| %>
          <article
            class="kitchen-card"
            data-card-filter-target="card"
            data-search="<%= [tenant.name, tenant.city, tenant.region, tenant.country, tenant.status].compact.join(' ') %>"
          >
            <div class="kitchen-visual">
              <%= tenant_placeholder_image(tenant, alt: "Imagen de #{tenant.name}") %>
              <div class="status-badge-float">
                <%= status_pill(tenant.status) %>
              </div>
            </div>

            <div class="kitchen-body">
              <h2 class="kitchen-title"><%= tenant.name %></h2>
              
              <div class="kitchen-meta">
                <div class="meta-item">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                  <span><%= present_or_dash(tenant.address) %></span>
                </div>
                <div class="meta-item">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                  <span><%= present_or_dash([tenant.city, tenant.region].compact.join(", ")) %></span>
                </div>
              </div>

              <div class="kitchen-actions">
                <%= link_to public_tenant_menu_today_path(slug: tenant.slug), class: "btn-kitchen btn-primary" do %>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"></path><path d="M7 2v20"></path><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"></path></svg>
                  <span>Menú Hoy</span>
                <% end %>
                
                <% if (map_link = tenant_map_link(tenant)).present? %>
                  <%= link_to map_link, target: "_blank", rel: "noreferrer", class: "btn-kitchen btn-secondary", title: "Ver ubicación" do %>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon><line x1="8" y1="2" x2="8" y2="18"></line><line x1="16" y1="6" x2="16" y2="22"></line></svg>
                  <% end %>
                <% else %>
                  <%= link_to public_tenant_path(tenant.slug), class: "btn-kitchen btn-secondary", title: "Más info" do %>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                  <% end %>
                <% end %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state" style="padding: 4rem 2rem;">
        <div style="background: var(--bg); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem; color: var(--text-muted); opacity: 0.3;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
        </div>
        <h3 style="font-family: 'Outfit', sans-serif; font-size: 1.5rem; margin-bottom: 0.5rem;">No hay comedores disponibles</h3>
        <p class="muted">Intenta buscar en otra ciudad o vuelve más tarde.</p>
      </div>
    <% end %>

    <div class="empty-state" data-card-filter-target="empty" style="display: none; padding: 5rem 2rem;">
      <div style="background: var(--bg); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem; color: var(--text-muted); opacity: 0.3;">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </div>
      <h3 style="font-family: 'Outfit', sans-serif; font-size: 1.5rem; margin-bottom: 0.5rem;">Vaya, no hay resultados</h3>
      <p class="muted">Prueba con otros términos de búsqueda como ciudad o nombre.</p>
      <button class="btn btn-secondary btn-sm" style="margin-top: 2rem;" data-action="click->card-filter#clear">Limpiar búsqueda</button>
    </div>
  </div>
</div>
