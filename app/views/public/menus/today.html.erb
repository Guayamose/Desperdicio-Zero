<% hours_rows = operating_hours_rows(@tenant.operating_hours_json) %>
<% location_text = [@tenant.address, @tenant.city, @tenant.region, @tenant.country].map(&:presence).compact.join(", ") %>

<section class="menu-today-page">
  <header class="menu-today-card menu-today-header">
    <div>
      <p class="eyebrow">Menu diario</p>
      <h1 class="page-title"><%= @tenant.name %></h1>
      <p class="page-subtitle">Consulta de menu para <%= ui_date(Date.current) %></p>
    </div>
    <div class="menu-today-header-toolbar">
      <%= status_pill(@menu.present? ? @menu.status : "inactive") %>
      <%= link_to "Volver al comedor", public_tenant_path(@tenant.slug), class: "btn btn-secondary btn-sm" %>
      <%= link_to "Todos los comedores", public_tenants_path, class: "btn btn-secondary btn-sm" %>
    </div>
  </header>

  <div class="menu-today-layout">
    <article class="menu-today-card menu-today-main">
      <% if @menu.present? %>
        <div class="menu-today-main-head">
          <div>
            <p class="menu-today-kicker">Menu del dia</p>
            <h2 class="menu-today-title"><%= @menu.title %></h2>
          </div>
          <%= status_pill(@menu.status) %>
        </div>

        <p class="menu-today-description"><%= present_or_dash(@menu.description) %></p>

        <% if @menu.allergens_json.present? %>
          <div class="menu-today-allergens">
            <strong>Alergenos generales:</strong>
            <%= allergen_badges(Array(@menu.allergens_json), wrapper_class: "allergen-badge-group allergen-badge-group-inline") %>
          </div>
        <% end %>

        <h3 class="menu-today-section-title">Platos del menu</h3>
        <% if @menu.daily_menu_items.any? %>
          <ol class="menu-today-dishes">
            <% @menu.daily_menu_items.each_with_index do |item, index| %>
              <li class="menu-today-dish">
                <div class="menu-today-dish-head">
                  <span class="menu-today-dish-number">Plato <%= index + 1 %></span>
                  <h4 class="menu-today-dish-title"><%= item.name %></h4>
                </div>

                <p class="menu-today-dish-description"><%= present_or_dash(item.description) %></p>

                <% if item.ingredients_json.present? %>
                  <div class="menu-today-ingredients">
                    <span class="menu-today-meta-label">Ingredientes</span>
                    <div class="menu-today-chip-group">
                      <% Array(item.ingredients_json).each do |ingredient| %>
                        <span class="menu-today-chip"><%= ingredient %></span>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <% if item.allergens_json.present? %>
                  <div class="menu-today-allergens menu-today-allergens-inline">
                    <strong>Alergenos:</strong>
                    <%= allergen_badges(Array(item.allergens_json), wrapper_class: "allergen-badge-group allergen-badge-group-inline") %>
                  </div>
                <% end %>
              </li>
            <% end %>
          </ol>
        <% else %>
          <div class="empty-state">El menu esta publicado pero todavia no tiene platos detallados.</div>
        <% end %>
      <% else %>
        <div class="empty-state">No hay menu publicado para hoy en este comedor.</div>
      <% end %>
    </article>

    <aside class="menu-today-side">
      <article class="menu-today-card menu-today-kitchen">
        <h2>Comedor y ubicacion</h2>

        <div class="menu-today-facts">
          <div class="menu-today-fact">
            <span class="menu-today-fact-label">Nombre</span>
            <span class="menu-today-fact-value"><%= @tenant.name %></span>
          </div>
          <div class="menu-today-fact">
            <span class="menu-today-fact-label">Calle</span>
            <span class="menu-today-fact-value"><%= present_or_dash(@tenant.address) %></span>
          </div>
          <div class="menu-today-fact">
            <span class="menu-today-fact-label">Ubicacion completa</span>
            <span class="menu-today-fact-value"><%= present_or_dash(location_text) %></span>
          </div>
        </div>

        <h3 class="menu-today-section-title">Horario del comedor</h3>
        <% if hours_rows.any? %>
          <ul class="menu-today-hours-list">
            <% hours_rows.each do |day, period| %>
              <li class="menu-today-hours-item">
                <span class="menu-today-hours-day"><%= "#{day}:" %></span>
                <span class="menu-today-hours-slot"><%= period %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="empty-state">Horario no disponible.</div>
        <% end %>

        <div class="map-shell menu-today-map">
          <% if (map_url = tenant_map_embed_url(@tenant)).present? %>
            <iframe class="map-frame" src="<%= map_url %>" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          <% else %>
            <%= map_placeholder_image %>
          <% end %>
        </div>
        <div class="menu-today-actions">
          <% if (map_link = tenant_map_link(@tenant)).present? %>
            <%= link_to "Abrir en OpenStreetMap", map_link, target: "_blank", rel: "noreferrer", class: "btn btn-secondary btn-sm" %>
          <% end %>
        </div>
      </article>

      <article class="menu-today-card menu-today-history">
        <h3 class="menu-today-section-title">Historial reciente</h3>
        <% if @recent_menus.any? %>
          <ul class="menu-today-history-list">
            <% @recent_menus.each do |menu| %>
              <li class="menu-today-history-item">
                <strong><%= menu.title %></strong>
                <span class="menu-today-history-date"><%= ui_date(menu.menu_date) %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="empty-state">No hay menus historicos publicados.</div>
        <% end %>
      </article>
    </aside>
  </div>
</section>
