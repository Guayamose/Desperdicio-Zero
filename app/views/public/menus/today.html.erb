<section class="page-header page-header-loose">
  <div>
    <p class="eyebrow">Menu diario</p>
    <h1 class="page-title"><%= @tenant.name %></h1>
    <p class="page-subtitle">Consulta de menu para <%= ui_date(Date.current) %></p>
  </div>
  <div class="toolbar">
    <%= status_pill(@menu.present? ? @menu.status : "inactive") %>
    <%= link_to "Volver al comedor", public_tenant_path(@tenant.slug), class: "btn btn-secondary btn-sm" %>
    <%= link_to "Todos los comedores", public_tenants_path, class: "btn btn-secondary btn-sm" %>
  </div>
</section>

<section class="split-panel">
  <article class="panel">
    <% if @menu.present? %>
      <% planning = @menu.planning_notes_json.is_a?(Hash) ? @menu.planning_notes_json : {} %>
      <% nutrition_summary = @menu.nutrition_summary_json.is_a?(Hash) ? @menu.nutrition_summary_json : {} %>
      <% dietary = @menu.dietary_guidance_json.is_a?(Hash) ? @menu.dietary_guidance_json : {} %>

      <div class="title-row mb-sm">
        <h2><%= @menu.title %></h2>
        <%= status_pill(@menu.status) %>
      </div>

      <p><%= present_or_dash(@menu.description) %></p>

      <div class="menu-smart-summary menu-smart-summary-public">
        <div class="menu-smart-summary-card">
          <h3>Plan de servicio</h3>
          <p><%= present_or_dash(planning["strategy"]) %></p>
          <div class="menu-inline-metrics">
            <% if planning["estimatedTotalServings"].present? %>
              <span class="menu-inline-metric"><strong><%= planning["estimatedTotalServings"] %></strong> raciones</span>
            <% end %>
            <% if planning["productionMode"].present? %>
              <span class="menu-inline-metric"><strong>Modo:</strong> <%= planning["productionMode"] %></span>
            <% end %>
          </div>
        </div>

        <div class="menu-smart-summary-card">
          <h3>Nutricion</h3>
          <div class="menu-nutrition-grid menu-nutrition-grid-compact">
            <% if nutrition_summary["estimatedAverageKcalPerServing"].present? %>
              <div class="menu-nutrition-item"><span>Kcal / racion</span><strong><%= nutrition_summary["estimatedAverageKcalPerServing"] %></strong></div>
            <% end %>
            <% if nutrition_summary["proteinFocus"].present? %>
              <div class="menu-nutrition-item"><span>Proteina</span><strong><%= nutrition_summary["proteinFocus"] %></strong></div>
            <% end %>
            <% if nutrition_summary["carbFocus"].present? %>
              <div class="menu-nutrition-item"><span>Carbs</span><strong><%= nutrition_summary["carbFocus"] %></strong></div>
            <% end %>
            <% if nutrition_summary["fatFocus"].present? %>
              <div class="menu-nutrition-item"><span>Grasa</span><strong><%= nutrition_summary["fatFocus"] %></strong></div>
            <% end %>
          </div>
        </div>

        <div class="menu-smart-summary-card">
          <h3>Compatibilidad</h3>
          <div class="menu-inline-metrics">
            <% if dietary["halalStatus"].present? %>
              <span class="menu-inline-metric"><strong>Halal:</strong> <%= dietary["halalStatus"] %></span>
            <% end %>
            <% if Array(dietary["haramRisks"]).any? %>
              <span class="menu-inline-metric is-warning"><strong>Riesgo haram:</strong> <%= Array(dietary["haramRisks"]).join(", ") %></span>
            <% end %>
          </div>
          <% if dietary["religiousNotes"].present? %>
            <p class="help-text"><strong>Nota:</strong> <%= dietary["religiousNotes"] %></p>
          <% end %>
        </div>
      </div>

      <% if @menu.allergens_json.present? %>
        <h3 class="section-title mt-md">Alergenos generales</h3>
        <div class="menu-chip-group">
          <% Array(@menu.allergens_json).each do |allergen| %>
            <span class="menu-chip menu-chip-danger"><%= allergen %></span>
          <% end %>
        </div>
      <% end %>

      <h3 class="section-title mt-md">Platos del menu</h3>
      <% if @menu.daily_menu_items.any? %>
        <div class="menu-dishes-grid menu-dishes-grid-rich">
          <% @menu.daily_menu_items.each_with_index do |item, index| %>
            <% nutrition = item.nutrition_json.is_a?(Hash) ? item.nutrition_json : {} %>
            <article class="menu-dish-card">
              <div class="menu-dish-head">
                <h3><%= item.name %></h3>
                <span class="status-pill status-neutral">Plato <%= index + 1 %></span>
              </div>
              <p><%= present_or_dash(item.description) %></p>

              <div class="menu-inline-metrics">
                <span class="menu-inline-metric"><strong>Raciones:</strong> <%= item.total_servings %></span>
                <% if nutrition["kcal"].present? %>
                  <span class="menu-inline-metric"><strong><%= nutrition["kcal"] %></strong> kcal/racion</span>
                <% end %>
              </div>

              <% if item.ingredients_json.present? %>
                <p class="help-text"><strong>Ingredientes:</strong> <%= Array(item.ingredients_json).join(", ") %></p>
              <% end %>

              <% if item.allergens_json.present? %>
                <div class="menu-chip-group">
                  <% Array(item.allergens_json).each do |allergen| %>
                    <span class="menu-chip menu-chip-danger"><%= allergen %></span>
                  <% end %>
                </div>
              <% end %>

              <% if item.dietary_flags_json.present? %>
                <div class="menu-chip-group">
                  <% Array(item.dietary_flags_json).each do |flag| %>
                    <span class="menu-chip menu-chip-info"><%= flag %></span>
                  <% end %>
                </div>
              <% end %>

              <% if item.religious_notes.present? %>
                <p class="menu-note menu-note-warning"><strong>Nota religiosa:</strong> <%= item.religious_notes %></p>
              <% end %>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">El menu esta publicado pero todavia no tiene platos detallados.</div>
      <% end %>
    <% else %>
      <div class="empty-state">No hay menu publicado para hoy en este comedor.</div>
    <% end %>
  </article>

  <article class="panel panel-soft">
    <h2>Comedor y ubicacion</h2>
    <div class="media-card">
      <div class="media-card-visual">
        <%= tenant_placeholder_image(@tenant, alt: "Imagen de referencia de #{@tenant.name}") %>
      </div>
      <div class="media-card-body">
        <strong><%= @tenant.name %></strong>
        <p class="muted"><%= present_or_dash([@tenant.city, @tenant.region, @tenant.country].compact.join(", ")) %></p>
      </div>
    </div>

    <div class="map-shell">
      <% if (map_url = tenant_map_embed_url(@tenant)).present? %>
        <iframe class="map-frame" src="<%= map_url %>" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      <% else %>
        <%= map_placeholder_image %>
      <% end %>
    </div>
    <div class="actions mt-sm">
      <% if (map_link = tenant_map_link(@tenant)).present? %>
        <%= link_to "Abrir en OpenStreetMap", map_link, target: "_blank", rel: "noreferrer", class: "btn btn-secondary btn-sm" %>
      <% end %>
    </div>

    <h3 class="section-title mt-md">Historial reciente</h3>
    <% if @recent_menus.any? %>
      <ul class="list-clean">
        <% @recent_menus.each do |menu| %>
          <li class="menu-item">
            <strong><%= menu.title %></strong>
            <p class="help-text"><%= ui_date(menu.menu_date) %></p>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="empty-state">No hay menus historicos publicados.</div>
    <% end %>
  </article>
</section>
