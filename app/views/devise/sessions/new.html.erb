<section class="page-header page-header-loose">
  <div>
    <p class="eyebrow">Acceso privado</p>
    <h1 class="page-title">Iniciar sesión</h1>
    <p class="page-subtitle">Accede al panel interno de comedores y administración global.</p>
  </div>
</section>

<section class="auth-shell">
  <article class="auth-card">
    <h2>Credenciales</h2>
    <p class="muted">Introduce tus credenciales para acceder al panel privado.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="field">
        <%= f.label :email, "Email" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div class="field">
        <%= f.label :password, "Contraseña" %>
        <%= f.password_field :password, autocomplete: "current-password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="field field-inline">
          <%= f.label :remember_me do %>
            <%= f.check_box :remember_me %>
            Recordarme
          <% end %>
        </div>
      <% end %>

      <div class="actions">
        <%= f.submit "Entrar", class: "btn btn-primary" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </article>

  <article class="auth-card auth-side">
    <h3>Accesos de demo</h3>
    <ul class="list-clean">
      <li class="menu-item">
        <strong>Admin global</strong>
        <p class="help-text">admin@socialkitchen.local</p>
        <p class="help-text">ChangeMe123!</p>
      </li>
      <li class="menu-item">
        <strong>Manager (Comedor Central)</strong>
        <p class="help-text">manager@test.com</p>
        <p class="help-text">manager123</p>
      </li>
      <li class="menu-item">
        <strong>Manager (Comedor Río)</strong>
        <p class="help-text">manager2@test.com</p>
        <p class="help-text">manager123</p>
      </li>
      <li class="menu-item">
        <strong>Manager (Comedor Marina)</strong>
        <p class="help-text">manager3@test.com</p>
        <p class="help-text">manager123</p>
      </li>
      <li class="menu-item">
        <strong>Staff (Comedor Central)</strong>
        <p class="help-text">staff@test.com</p>
        <p class="help-text">staff1234</p>
      </li>
    </ul>
  </article>
</section>
