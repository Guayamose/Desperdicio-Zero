<!DOCTYPE html>
<html>
  <head>
    <title>Social Kitchen Dashboard</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body class="app-area app-area-<%= current_area %>">
    <a class="skip-link" href="#main-content">Saltar al contenido</a>

    <header class="app-header" data-controller="nav">
      <div class="container header-inner">
        <%= link_to root_path, class: "brand-block" do %>
          <div class="brand-icon">
            <%= image_tag "brand/Logo-app.png", alt: "Logo Desperdicio Cero", class: "brand-logo" %>
          </div>
          <div class="brand-text">
            <span class="brand-kicker">Desperdicio Cero</span>
            <span class="brand-title">Social Kitchen</span>
          </div>
        <% end %>

        <nav class="nav-main" data-nav-target="menu">
          <%= nav_link_to root_path do %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            Portal
          <% end %>
          <%= nav_link_to public_tenants_path do %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            Comedores
          <% end %>

          <% if user_signed_in? && system_admin? %>
            <%= nav_link_to admin_root_path do %>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4z"></path><path d="M9 12l2 2 4-4"></path></svg>
              Admin
            <% end %>
          <% end %>

          <% if user_signed_in? && current_tenant.present? %>
            <%= nav_link_to tenant_dashboard_path do %>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
              Mi Comedor
            <% end %>
          <% end %>
        </nav>

        <div class="user-context">
          <% if user_signed_in? %>
            <% if current_tenant.present? %>
              <div class="tenant-badge">
                <%= current_tenant.name %>
              </div>
            <% end %>

            <%= link_to tenant_profile_path, class: "avatar-btn", title: current_user.full_name do %>
              <%= current_user.full_name.split.map(&:first).first(2).join.upcase %>
            <% end %>

            <%= button_to "Salir", destroy_user_session_path, method: :delete, class: "btn btn-secondary btn-sm", style: "border-radius: 99px; padding: 0.4rem 1rem;" %>
          <% else %>
            <%= link_to "Iniciar Sesión", new_user_session_path, class: "btn btn-primary btn-sm" %>
          <% end %>
        </div>

        <button type="button" class="nav-toggle" data-action="nav#toggle">
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>

    <% nav_items = area_nav_items %>
    <% if nav_items.any? && current_area != :public %>
      <nav class="section-nav">
        <div class="container section-nav-inner">
          <div class="section-links">
            <% nav_items.each do |label, path| %>
              <%= area_nav_link_to(label, path) %>
            <% end %>
          </div>
        </div>
      </nav>
    <% end %>

    <%= yield :hero %>

    <main id="main-content" class="container main-shell">
      <% if flash.any? %>
        <div class="flash-stack">
          <% flash.each do |type, message| %>
            <% flash_type = type.to_s == "alert" ? "alert" : "notice" %>
            <div class="flash <%= flash_type %>" data-controller="flash" data-flash-timeout-value="5000">
              <span><%= message %></span>
              <button type="button" class="flash-close" aria-label="Cerrar" data-action="flash#dismiss">x</button>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <section>
          <div class="footer-brand">
            <%= image_tag "brand/Logo-app.png", alt: "Logo Desperdicio Cero", class: "footer-brand-logo" %>
            <h4>Social Kitchen</h4>
          </div>
          <p>Gestión inteligente para comedores sociales con foco en reducción de desperdicio.</p>
        </section>

        <section>
          <h4>Navegación</h4>
          <ul class="footer-links">
            <li><%= link_to "Comedores", public_tenants_path %></li>
            <li><%= link_to "Acceso interno", new_user_session_path %></li>
          </ul>
        </section>

        <section>
          <h4>Soporte</h4>
          <ul class="footer-links">
            <li>soporte@socialkitchen.local</li>
            <li>+34 900 100 200</li>
          </ul>
        </section>

        <section>
          <h4>Legal</h4>
          <ul class="footer-links">
            <li><%= link_to "Política de Privacidad", privacy_policy_path %></li>
          </ul>
        </section>
      </div>

      <div class="container footer-bottom">
        <span class="footer-copyright">
          <%= image_tag "brand/Logo-app.png", alt: "Logo Desperdicio Cero", class: "footer-mini-logo" %>
          &copy; <%= Time.current.year %> Social Kitchen
        </span>
        <span>Rails + Turbo</span>
      </div>
    </footer>
  </body>
</html>
